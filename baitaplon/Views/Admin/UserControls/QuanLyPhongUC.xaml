<UserControl x:Class="Quanlynhatro.Views.Admin.UserControls.QuanLyPhongUC"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:models="clr-namespace:Quanlynhatro.Models"
              Background="#FFFFFF">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Primary Button (Xanh dương) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0052A3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0052A3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#888888"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button (Đỏ) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="BorderBrush" Value="#B31412"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B31412"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Success Button (Xanh lá) -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#1E8E3E"/>
            <Setter Property="BorderBrush" Value="#137333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#137333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button (Xám) -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0066CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="GridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#CCCCCC"/>
            <Setter Property="VerticalGridLinesBrush" Value="#CCCCCC"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="28"/>
            <Style.Resources>
                <!-- Overrides default inactive selection colors to prevent faded white text when losing focus -->
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E2E8F0"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
            </Style.Resources>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F2F2F2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell alignment styles -->
        <Style x:Key="LeftAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
        <Style x:Key="CenterAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RightAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="BoldRightAlignStyle" TargetType="TextBlock" BasedOn="{StaticResource RightAlignStyle}">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" Padding="20,15,20,12" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="🏠 Danh Sách Phòng Trọ" FontSize="20" FontWeight="Bold" Foreground="#0066CC"/>
                    <TextBlock Text="Quản lý thông tin, diện tích, giá thuê và tiện ích phòng" FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="✏️ Sửa phòng" Style="{StaticResource SecondaryBtn}" 
                            Command="{Binding SuaPhongCommand}" Margin="0,0,6,0"
                            IsEnabled="{Binding CoPhongDangChon}"/>
                    <Button Content="🗑️ Xóa phòng" Style="{StaticResource DangerBtn}" 
                            Command="{Binding XoaPhongCommand}" Margin="0,0,6,0"
                            IsEnabled="{Binding CoPhongDangChon}"/>
                    <Button Content="➕ Thêm phòng mới" Style="{StaticResource PrimaryBtn}" 
                            Command="{Binding ThemPhongCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FFFFFF" Padding="20,10,20,10" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#F2F7FB" BorderBrush="#B9D3EE" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SoPhongTong}" FontSize="22" FontWeight="Bold" Foreground="#0066CC" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tổng số phòng" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#EAFaf1" BorderBrush="#A9DFBF" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SoPhongTrong}" FontSize="22" FontWeight="Bold" Foreground="#1E8E3E" HorizontalAlignment="Center"/>
                        <TextBlock Text="Phòng đang trống" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FEF9E7" BorderBrush="#F9E79F" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SoPhongDangThue}" FontSize="22" FontWeight="Bold" Foreground="#B06000" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đang cho thuê" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#FDF2F2" BorderBrush="#FADBD8" BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding SoPhongSuaChua}" FontSize="22" FontWeight="Bold" Foreground="#D93025" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đang sửa chữa" FontSize="10" Foreground="#555555" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="4" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             Height="30" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding DanhSachTrangThai}"
                              SelectedItem="{Binding LocTrangThai}"
                              Style="{StaticResource ComboStyle}" Height="30"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,10,20,15">
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <DataGrid ItemsSource="{Binding DanhSachPhong}" 
                          SelectedItem="{Binding PhongDangChon}"
                          Style="{StaticResource GridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phòng" Binding="{Binding TenPhong}" Width="80" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Loại" Binding="{Binding LoaiPhongText}" Width="110" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Tầng" Binding="{Binding Tang}" Width="70" ElementStyle="{StaticResource CenterAlignStyle}"/>
                        <DataGridTextColumn Header="Diện tích" Binding="{Binding DienTich, StringFormat={}{0} m²}" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                        <DataGridTextColumn Header="Giá thuê/tháng" Width="130" ElementStyle="{StaticResource RightAlignStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="GiaThue" StringFormat="{}{0:N0} đ"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Giá điện/kWh" Width="110" ElementStyle="{StaticResource RightAlignStyle}">
                            <DataGridTextColumn.Binding>
                                <Binding Path="GiaDien" StringFormat="{}{0:N0} đ"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Nội thất" Binding="{Binding TrangThaiNoiThat}" Width="100" ElementStyle="{StaticResource LeftAlignStyle}"/>
                        <DataGridTextColumn Header="Tiện ích kèm theo" Binding="{Binding TienIchText}" Width="*" ElementStyle="{StaticResource LeftAlignStyle}"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="135">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" Margin="2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrangThaiText}" Value="Trống">
                                                        <Setter Property="Background" Value="#E6F4EA"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang thuê">
                                                        <Setter Property="Background" Value="#E8F0FE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang sửa chữa">
                                                        <Setter Property="Background" Value="#FEF7E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang dọn">
                                                        <Setter Property="Background" Value="#F3E8FD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding TrangThaiText}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TrangThaiText}" Value="Trống">
                                                            <Setter Property="Foreground" Value="#137333"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang thuê">
                                                            <Setter Property="Foreground" Value="#1A73E8"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang sửa chữa">
                                                            <Setter Property="Foreground" Value="#B06000"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TrangThaiText}" Value="Đang dọn">
                                                            <Setter Property="Foreground" Value="#8430FD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3" Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}">
            <Rectangle Fill="Black" Opacity="0.4"/>
            <Border Background="White" CornerRadius="4" Width="600" MaxHeight="680"
                    BorderBrush="#777777" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="25">
                        <Border Margin="0,0,0,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,0,0,8">
                            <Grid>
                                <TextBlock Text="{Binding FormTitle}" FontSize="16" FontWeight="Bold" Foreground="#0066CC"/>
                                <Button Content="✕" HorizontalAlignment="Right" Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding HuyCommand}" Width="24" Height="24" Padding="0"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Tên/Số phòng *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.TenPhong, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                <TextBlock Text="Loại phòng" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding DanhSachLoaiPhong}"
                                          SelectedItem="{Binding FormPhong.LoaiPhong}"
                                          Style="{StaticResource ComboStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <Binding Path="." Converter="{x:Null}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tầng ở" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.Tang, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Diện tích (m²)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.DienTich, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Giá thuê một tháng (đ) *" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.GiaThue, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Giá điện /kWh (đ)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.GiaDien, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                <TextBlock Text="Giá nước /m³ (đ)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.GiaNuoc, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Internet /tháng (đ)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FormPhong.GiaInternet, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Height="30"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Trang bị nội thất" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding DanhSachNoiThat}"
                                          SelectedItem="{Binding FormPhong.TrangThaiNoiThat}"
                                          Style="{StaticResource ComboStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Trạng thái phòng" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding DanhSachTrangThaiPhong}"
                                          SelectedItem="{Binding FormPhong.TrangThai}"
                                          Style="{StaticResource ComboStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="CÁC TIỆN ÍCH CÓ SẴN" Style="{StaticResource LabelStyle}" Margin="0,4,0,6"/>
                        <WrapPanel Margin="0,0,0,12">
                            <CheckBox Content="Mạng WiFi" IsChecked="{Binding FormPhong.CoWifi}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Điều hòa" IsChecked="{Binding FormPhong.CoDieuHoa}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Nóng lạnh" IsChecked="{Binding FormPhong.CoNongLanh}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Máy giặt" IsChecked="{Binding FormPhong.CoMayGiat}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Nhà bếp" IsChecked="{Binding FormPhong.CoBep}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Nơi gửi xe" IsChecked="{Binding FormPhong.CoGiuXeMay}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Tủ lạnh" IsChecked="{Binding FormPhong.CoTuLanh}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                            <CheckBox Content="Tivi" IsChecked="{Binding FormPhong.CoTivi}" Foreground="Black" Margin="0,0,12,6" FontSize="12"/>
                        </WrapPanel>

                        <TextBlock Text="Ghi chú mô tả" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding FormPhong.MoTa, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}" Height="60" 
                                 TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"
                                 VerticalContentAlignment="Top"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="Hủy bỏ" Style="{StaticResource SecondaryBtn}" 
                                    Command="{Binding HuyCommand}" Margin="0,0,6,0" Width="80"/>
                            <Button Content="💾 Lưu lại" Style="{StaticResource SuccessBtn}" 
                                    Command="{Binding LuuPhongCommand}" Width="110"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
