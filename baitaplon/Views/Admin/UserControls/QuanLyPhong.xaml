<UserControl x:Class="Quanlynhatro.Views.Admin.UserControls.QuanLyKhachUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="640" Width="1000"
             Background="White">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="QUẢN LÝ KHÁCH THUÊ &amp; HỢP ĐỒNG" FontSize="20" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20"/>

            <!-- Khách Thuê Section -->
            <TextBlock Text="Danh Sách Khách Thuê" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid ItemsSource="{Binding DanhSachKhach}" SelectedItem="{Binding KhachDangChon}"
                      AutoGenerateColumns="False" Height="180" Background="White" Margin="0,0,0,20" SelectionChanged="DataGrid_SelectionChanged_1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã Khách" Binding="{Binding KhachID}" Width="80"/>
                    <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="150"/>
                    <DataGridTextColumn Header="Điện Thoại" Binding="{Binding SoDienThoai}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="120"/>
                    <DataGridTextColumn Header="Ngày Vào Ở" Binding="{Binding NgayVaoO}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Hợp Đồng Section -->
            <TextBlock Text="Danh Sách Hợp Đồng" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid ItemsSource="{Binding DanhSachHopDong}" SelectedItem="{Binding HopDongDangChon}"
                      AutoGenerateColumns="False" Height="180" Background="White" Margin="0,0,0,20" SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã HĐ" Binding="{Binding HopDongID}" Width="80"/>
                    <DataGridTextColumn Header="Mã Khách" Binding="{Binding KhachID}" Width="80"/>
                    <DataGridTextColumn Header="Mã Phòng" Binding="{Binding PhongID}" Width="80"/>
                    <DataGridTextColumn Header="Ngày Bắt Đầu" Binding="{Binding NgayBatDau}" Width="100"/>
                    <DataGridTextColumn Header="Ngày Kết Thúc" Binding="{Binding NgayKetThuc}" Width="100"/>
                    <DataGridTextColumn Header="Giá Cố Định" Binding="{Binding GiaCoDinh}" Width="100"/>
                    <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Duyệt Khách" Width="150" Height="35" Background="#27ae60" Foreground="White"
                        Command="{Binding DuyetKhachCommand}" Margin="0,0,10,0"/>
                <Button Content="Cập Nhật Hợp Đồng" Width="150" Height="35" Background="#3498db" Foreground="White"
                        Command="{Binding CapNhatHopDongCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>