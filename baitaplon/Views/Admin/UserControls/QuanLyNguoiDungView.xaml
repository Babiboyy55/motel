<UserControl x:Class="baitaplon.Views.Admin.UserControls.QuanLyNguoiDungView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Column: User Account Management -->
        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="QUẢN LÝ TÀI KHOẢN" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button Content="+ Cấp Tài Khoản Mới" Command="{Binding MoFormThemCommand}" Background="#27AE60" Foreground="White" Padding="15,8" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="{Binding NutKhoaText}" Command="{Binding KhoaMoKhoaCommand}" Background="{Binding NutKhoaMau}" Foreground="White" Padding="15,8" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding DanhSachNguoiDung}" SelectedItem="{Binding NguoiDungDangChon, Mode=TwoWay}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Tên Đăng Nhập" Binding="{Binding TenDangNhap}" Width="*"/>
                        <DataGridTextColumn Header="Họ Tên" Binding="{Binding TenNguoiDung}" Width="*"/>
                        <DataGridTextColumn Header="Phân Quyền" Binding="{Binding VaiTro}" Width="*"/>
                        <DataGridTextColumn Header="Số Điện Thoại" Binding="{Binding SoDienThoai}" Width="*"/>
                        <DataGridTemplateColumn Header="Trạng thái" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="5,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TrangThai}" Value="True">
                                                        <Setter Property="Text" Value="Hoạt động"/>
                                                        <Setter Property="Foreground" Value="#27AE60"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                                        <Setter Property="Text" Value="Bị khóa"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right Column: Audit Log -->
        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="⏱️ NHẬT KÝ HOẠT ĐỘNG" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <ListView Grid.Row="1" ItemsSource="{Binding DanhSachNhatKy}" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="{Binding NguoiDung.TenNguoiDung}" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding ThoiGian, StringFormat=dd/MM/yyyy HH:mm}" Foreground="#7F8C8D" FontSize="11"/>
                                </StackPanel>
                                <TextBlock Text="{Binding HanhDong}" TextWrapping="Wrap" Foreground="#34495E" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ChiTiet}" TextWrapping="Wrap" Foreground="#7F8C8D" FontSize="12" Margin="0,2,0,0"/>
                                <Rectangle Height="1" Fill="#ECF0F1" Margin="0,10,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Overlay Dialog Form for Adding User -->
        <Grid Background="#80000000" Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVis}}" Panel.ZIndex="1000" Grid.ColumnSpan="2" Margin="-20">
            <Border Background="White" CornerRadius="10" Width="400" Height="480" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CẤP TÀI KHOẢN MỚI" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Tên đăng nhập" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                        <TextBox Text="{Binding TenDangNhapInput, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5,0" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Họ và tên" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                        <TextBox Text="{Binding TenNguoiDungInput, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5,0" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Mật khẩu" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                        <TextBox Text="{Binding MatKhauInput, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5,0" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Số điện thoại" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                        <TextBox Text="{Binding SoDienThoaiInput, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5,0" Margin="0,0,0,12" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Vai trò / Phân quyền" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#34495E"/>
                        <ComboBox ItemsSource="{Binding DanhSachVaiTro}" SelectedItem="{Binding VaiTroInput}" Height="35" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Hủy" Command="{Binding HuyCommand}" Background="#7F8C8D" Foreground="White" Width="107" Height="38" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Button_Click"/>
                        <Button Content="Cấp tài khoản" Command="{Binding LuuTaiKhoanCommand}" Background="#27AE60" Foreground="White" Width="130" Height="38" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel/>
        </Grid>
    </Grid>
</UserControl>