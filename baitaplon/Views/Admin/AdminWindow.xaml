<Window x:Class="Quanlynhatro.Views.Admin.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Quanlynhatro.ViewModels.Admin"
        xmlns:uc="clr-namespace:Quanlynhatro.Views.Admin.UserControls"
        Title="Chương trình Quản Lý Nhà Trọ - Bài Tập Lớn" 
        Height="780" Width="1280"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9">

    <Window.Resources>
        <!-- Nav Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Margin="6,2" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                             VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#1A73E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========================= SIDEBAR ========================= -->
        <Border Grid.Column="0" Background="#F0F2F5" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Background="#E5E7EB" Padding="15,20,15,15" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🏠" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="QUẢN LÝ NHÀ TRỌ" FontSize="12" FontWeight="Bold" 
                                   Foreground="#1A73E8" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="BÀI TẬP LỚN WPF" FontSize="9" Foreground="#666666" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Nav Menu -->
                <StackPanel DockPanel.Dock="Top" Margin="0,10,0,0">
                    <TextBlock Text="DANH MỤC CHỨC NĂNG" FontSize="10" Foreground="#555555" 
                               Margin="20,0,0,8" FontWeight="Bold"/>

                    <Button x:Name="btnPhong" Command="{Binding ShowQuanLyPhongCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuIndex}" Value="0">
                                        <Setter Property="Background" Value="#1A73E8"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Quản lý Phòng trọ" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnKhach" Command="{Binding ShowQuanLyKhachCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuIndex}" Value="1">
                                        <Setter Property="Background" Value="#1A73E8"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Quản lý Khách thuê" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnHoaDon" Command="{Binding ShowQuanLyHoaDonCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuIndex}" Value="2">
                                        <Setter Property="Background" Value="#1A73E8"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Hóa đơn &amp; Thu chi" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Stats mini -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,15">
                    <Rectangle Height="1" Fill="#CCCCCC" Margin="0,0,0,12"/>
                    <TextBlock Text="THÔNG TIN NHANH" FontSize="10" Foreground="#555555" FontWeight="Bold" Margin="4,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Border Background="#EBF5FE" BorderBrush="#B3D7FF" BorderThickness="1" CornerRadius="4" Padding="6,6" Margin="0,0,2,2">
                            <StackPanel>
                                <TextBlock Text="{Binding SoPhongTong}" FontSize="16" FontWeight="Bold" Foreground="#0D47A1" HorizontalAlignment="Center"/>
                                <TextBlock Text="Tổng số phòng" FontSize="9" Foreground="#555555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#E8F8F5" BorderBrush="#A2E9DB" BorderThickness="1" CornerRadius="4" Margin="2,0,0,2" Padding="6,6">
                            <StackPanel>
                                <TextBlock Text="{Binding SoPhongTrong}" FontSize="16" FontWeight="Bold" Foreground="#0E6251" HorizontalAlignment="Center"/>
                                <TextBlock Text="Phòng trống" FontSize="9" Foreground="#555555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Background="#FEF9E7" BorderBrush="#FADBD8" BorderThickness="1" CornerRadius="4" Margin="0,2,2,0" Padding="6,6">
                            <StackPanel>
                                <TextBlock Text="{Binding SoKhachDangO}" FontSize="16" FontWeight="Bold" Foreground="#78281F" HorizontalAlignment="Center"/>
                                <TextBlock Text="Khách thuê" FontSize="9" Foreground="#555555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Background="#FDEDEC" BorderBrush="#F5B7B1" BorderThickness="1" CornerRadius="4" Margin="2,2,0,0" Padding="6,6">
                            <StackPanel>
                                <TextBlock Text="{Binding SoHoaDonChuaTT}" FontSize="16" FontWeight="Bold" Foreground="#641E16" HorizontalAlignment="Center"/>
                                <TextBlock Text="Chưa thanh toán" FontSize="9" Foreground="#555555" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========================= CONTENT AREA ========================= -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:QuanLyPhongViewModel}">
                    <uc:QuanLyPhongUC/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:QuanLyKhachViewModel}">
                    <uc:QuanLyKhachUC/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:QuanLyHoaDonViewModel}">
                    <uc:QuanLyHoaDonUC/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
