<Window x:Class="Quanlynhatro.Views.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khôi phục mật khẩu" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F6FA" WindowStyle="None" AllowsTransparency="True">
    
    <Border Background="White" CornerRadius="12" BorderBrush="#DCDDE1" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid>
                <TextBlock Text="KHÔI PHỤC MẬT KHẨU" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                <Button Name="btnClose" Content="✕" Width="25" Height="25" Background="Transparent" BorderThickness="0" Foreground="#7F8C8D" FontWeight="Bold" Cursor="Hand" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnClose_Click"/>
            </Grid>

            <!-- Steps Container -->
            <Grid Grid.Row="1" Margin="0,20,0,20">
                <!-- STEP 1: Username & Phone -->
                <StackPanel Name="panelStep1" Visibility="Visible">
                    <TextBlock Text="Vui lòng nhập thông tin tài khoản đã đăng ký trên hệ thống để nhận mã OTP." TextWrapping="Wrap" Foreground="#7F8C8D" Margin="0,0,0,20" FontSize="13"/>
                    
                    <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Name="txtUsername" Height="38" Padding="10,0" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Số điện thoại nhận OTP" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Name="txtPhone" Height="38" Padding="10,0" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
                    
                    <Button Content="Gửi mã OTP qua SMS" Background="#3498DB" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="BtnSendOtp_Click"/>
                </StackPanel>

                <!-- STEP 2: Input OTP -->
                <StackPanel Name="panelStep2" Visibility="Collapsed">
                    <TextBlock Text="Hệ thống đã gửi một mã OTP gồm 6 chữ số tới số điện thoại của bạn. Vui lòng nhập mã để xác thực." TextWrapping="Wrap" Foreground="#7F8C8D" Margin="0,0,0,20" FontSize="13"/>

                    <TextBlock Text="Nhập mã OTP" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBox Name="txtOtp" Height="38" Padding="10,0" Margin="0,0,0,15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>

                    <Button Content="Xác nhận mã OTP" Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="BtnVerifyOtp_Click"/>
                    <Button Content="Quay lại" Background="Transparent" Foreground="#3498DB" Height="30" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="BtnBackToStep1_Click"/>
                </StackPanel>

                <!-- STEP 3: Reset Password -->
                <StackPanel Name="panelStep3" Visibility="Collapsed">
                    <TextBlock Text="Xác thực thành công! Vui lòng nhập mật khẩu mới cho tài khoản của bạn." TextWrapping="Wrap" Foreground="#27AE60" Margin="0,0,0,20" FontSize="13" FontWeight="SemiBold"/>

                    <TextBlock Text="Mật khẩu mới" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtNewPassword" Height="38" Padding="10,0" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Xác nhận mật khẩu mới" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtConfirmPassword" Height="38" Padding="10,0" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Button Content="Hoàn tất &amp; Lưu mật khẩu" Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="BtnResetPassword_Click"/>
                </StackPanel>
            </Grid>

            <!-- Error/Status message -->
            <TextBlock Name="lblMessage" Grid.Row="2" Text="" Foreground="#E74C3C" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
