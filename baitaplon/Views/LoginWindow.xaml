<Window x:Class="Quanlynhatro.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập - Hệ Thống Quản Lý Nhà Trọ" Height="420" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Style cho Button Đăng nhập -->
        <Style x:Key="LoginBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1557B0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0F3C80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Nút Close/Exit -->
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F3F4"/>
                                <Setter Property="Foreground" Value="#D93025"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1" Margin="10,10,10,-21">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Logo & Title -->
                <RowDefinition Height="Auto"/>
                <!-- Form Inputs -->
                <RowDefinition Height="Auto"/>
                <!-- Error Msg -->
                <RowDefinition Height="*"/>
                <!-- Action Buttons -->
            </Grid.RowDefinitions>

            <!-- Close Button in Top-Right -->
            <Button x:Name="btnClose" Style="{StaticResource CloseBtnStyle}" 
                    Content="✕" Width="24" Height="24" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Click="BtnClose_Click" Margin="0,-10,-10,0"/>

            <!-- Header Title -->
            <StackPanel Grid.Row="0" Margin="0,10,0,25" HorizontalAlignment="Center">
                <TextBlock Text="🏠" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="ĐĂNG NHẬP HỆ THỐNG" FontSize="18" FontWeight="Bold" Foreground="#1A73E8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Phần mềm Quản lý Nhà trọ" FontSize="11" Foreground="#5F6368" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Input Fields -->
            <StackPanel Grid.Row="1">
                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" FontSize="12" FontWeight="SemiBold" Foreground="#3C4043" Margin="0,0,0,6"/>
                <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="5" Background="#F8F9FA" Padding="8,5" Margin="0,0,0,15">
                    <TextBox x:Name="txtUsername" BorderThickness="0" Background="Transparent" FontSize="13" Foreground="Black" KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" FontSize="12" FontWeight="SemiBold" Foreground="#3C4043" Margin="0,0,0,6"/>
                <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="5" Background="#F8F9FA" Padding="8,5" Margin="0,0,0,10">
                    <PasswordBox x:Name="txtPassword" BorderThickness="0" Background="Transparent" FontSize="13" Foreground="Black" KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Remember Me & Forgot Password Link -->
                <Grid Margin="0,5,0,0">
                    <CheckBox x:Name="chkRememberMe" Content="Ghi nhớ tài khoản" FontSize="11" Foreground="#5F6368" VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Hyperlink Click="HlForgotPassword_Click" Foreground="#1A73E8" TextDecorations="None" FontSize="11" FontWeight="SemiBold">Quên mật khẩu?</Hyperlink>
                    </TextBlock>
                </Grid>
            </StackPanel>

            <!-- Error message text block -->
            <TextBlock x:Name="lblError" Grid.Row="2" Text="" Foreground="#D93025" FontSize="12" Margin="0,12,0,0" HorizontalAlignment="Center" FontWeight="Medium" TextWrapping="Wrap"/>

            <!-- Actions -->
            <Grid Grid.Row="3" Margin="0,20,0,0" VerticalAlignment="Bottom">
                <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Style="{StaticResource LoginBtnStyle}" Height="40" Click="BtnLogin_Click" Margin="0,-6,0,6"/>
            </Grid>
        </Grid>
    </Border>
</Window>
